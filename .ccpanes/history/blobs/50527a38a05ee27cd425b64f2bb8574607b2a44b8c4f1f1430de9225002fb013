from __future__ import annotations

from datetime import datetime, timezone
from typing import Any

from fastapi import FastAPI
from pydantic import BaseModel

from app.pipeline import build_candidate_bundles
from app.schemas import CandidateBundle, Decision, DecisionRecord, SearchRequest
from app.search_service import search_service
from app.storage import load_blacklist_summary, load_profit_summary, save_decision
from platforms.defaults import register_default_platforms
from platforms.registry import registry

register_default_platforms()

app = FastAPI(title="AI 选品助手", version="0.1.0")


class DecisionPayload(BaseModel):
    decision: Decision
    reason: str | None = None
    decided_by: str = "api-user"


def get_candidate_bundles() -> list[CandidateBundle]:
    return build_candidate_bundles()


def summarize_platform_opportunities(candidates: list[CandidateBundle]) -> list[dict[str, int | float | str]]:
    platform_metrics: dict[str, dict[str, int | float | str]] = {}

    for code in registry.codes(role="sell_target"):
        descriptor = registry.get(code)
        platform_metrics[code] = {
            "platform_code": code,
            "display_name": descriptor.descriptor.display_name if descriptor is not None else code,
            "candidate_count": 0,
            "approved_count": 0,
            "avg_product_score": 0.0,
            "avg_opportunity_score": 0.0,
            "total_estimated_profit": 0.0,
        }

    for candidate in candidates:
        platform_code = candidate.product.platform_code or candidate.product.platform.value
        metrics = platform_metrics.setdefault(
            platform_code,
            {
                "platform_code": platform_code,
                "display_name": platform_code,
                "candidate_count": 0,
                "approved_count": 0,
                "avg_product_score": 0.0,
                "avg_opportunity_score": 0.0,
                "total_estimated_profit": 0.0,
            },
        )
        metrics["candidate_count"] += 1
        metrics["avg_product_score"] += candidate.product.product_score
        metrics["avg_opportunity_score"] += (
            candidate.ai_recommendation.opportunity_score if candidate.ai_recommendation is not None else 0.0
        )
        if candidate.supplier is not None:
            metrics["total_estimated_profit"] += candidate.supplier.profit_est
        if candidate.decision is not None and candidate.decision.decision is Decision.APPROVED:
            metrics["approved_count"] += 1

    summary_rows: list[dict[str, int | float | str]] = []
    for metrics in platform_metrics.values():
        candidate_count = int(metrics["candidate_count"])
        if candidate_count > 0:
            metrics["avg_product_score"] = round(float(metrics["avg_product_score"]) / candidate_count, 2)
            metrics["avg_opportunity_score"] = round(float(metrics["avg_opportunity_score"]) / candidate_count, 2)
            metrics["total_estimated_profit"] = round(float(metrics["total_estimated_profit"]), 2)
        summary_rows.append(metrics)

    return sorted(summary_rows, key=lambda item: (float(item["avg_opportunity_score"]), float(item["avg_product_score"])), reverse=True)



def get_dashboard_summary() -> dict:
    candidates = get_candidate_bundles()
    decision_counts = {decision.value: 0 for decision in Decision}
    for candidate in candidates:
        if candidate.decision is not None:
            decision_counts[candidate.decision.decision.value] += 1

    profit_summary = load_profit_summary()
    blacklist_summary = load_blacklist_summary()
    return {
        "candidate_count": len(candidates),
        "sell_target_platforms": list(registry.codes(role="sell_target")),
        "supply_platforms": list(registry.codes(role="supply")),
        "platform_opportunities": summarize_platform_opportunities(candidates),
        **decision_counts,
        "total_profit_records": int(profit_summary["total_count"]),
        "total_profit_est": profit_summary["total_profit"],
        "supplier_blacklist_count": blacklist_summary["supplier_count"],
        "category_blacklist_count": blacklist_summary["category_count"],
    }


@app.get("/health")
def health() -> dict[str, str]:
    return {"status": "ok"}


@app.get("/api/candidates")
def list_candidates() -> list[dict]:
    return [candidate.model_dump(mode="json") for candidate in get_candidate_bundles()]


@app.get("/api/summary")
def get_summary() -> dict:
    return get_dashboard_summary()


@app.get("/api/platforms")
def list_platform_opportunities() -> list[dict[str, int | float | str]]:
    return summarize_platform_opportunities(get_candidate_bundles())


@app.post("/api/search")
def create_search(payload: SearchRequest) -> dict[str, Any]:
    session = search_service.start_search(payload)
    return {
        "status": "ok",
        "session": session.model_dump(mode="json"),
    }


@app.get("/api/search/{search_id}")
def get_search(search_id: str) -> dict[str, Any]:
    session = search_service.get_session(search_id)
    if session is None:
        return {"status": "not_found", "search_id": search_id}
    return {
        "status": "ok",
        "session": session.model_dump(mode="json"),
    }


@app.get("/api/search/{search_id}/hits")
def get_search_hits(search_id: str) -> dict[str, Any]:
    session = search_service.get_session(search_id)
    if session is None:
        return {"status": "not_found", "search_id": search_id}
    hits = search_service.get_hits(search_id)
    return {
        "status": "ok",
        "session": session.model_dump(mode="json"),
        "hits": [hit.model_dump(mode="json") for hit in hits],
    }


@app.post("/api/candidates/{product_id}/decision")
def save_candidate_decision(product_id: str, payload: DecisionPayload) -> dict:
    candidates = {candidate.product.id: candidate for candidate in get_candidate_bundles()}
    candidate = candidates.get(product_id)
    if candidate is None:
        return {"status": "not_found", "product_id": product_id}

    record = DecisionRecord(
        product_id=product_id,
        decision=payload.decision,
        reason=payload.reason,
        decided_by=payload.decided_by,
        decided_at=datetime.now(timezone.utc),
    )
    save_decision(
        record,
        supplier_name=candidate.supplier.supplier_name if candidate.supplier else None,
        category_label=candidate.product.category_label,
        profit_est=candidate.supplier.profit_est if candidate.supplier else None,
        supplier_id=candidate.supplier.supplier_id if candidate.supplier else None,
    )

    return {
        "status": "ok",
        "record": record.model_dump(mode="json"),
    }
