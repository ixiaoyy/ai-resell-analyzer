from __future__ import annotations

import json
from pathlib import Path

from analyzer import analyze_products
from app.ai import AIAssetBuilder
from app.schemas import (
    AIRecommendation,
    AnalyzedProduct,
    CandidateBundle,
    CopyDraft,
    DecisionRecord,
    ImageAsset,
    ListingCopyAsset,
    MatchedSupplier,
    RawProduct,
)
from app.storage import load_decisions
from copywriter import build_copy_drafts
from matcher import match_suppliers
from scraper.__main__ import ProductScraper

RAW_PATH = Path("data") / "raw" / "all_latest.json"
ANALYZED_PATH = Path("data") / "analyzed" / "analyzed_latest.json"
MATCHED_PATH = Path("data") / "matched" / "matched_latest.json"
COPY_PATH = Path("data") / "copydrafts" / "copydrafts_latest.json"


def build_pipeline_outputs(
    use_sample_fallback: bool = True,
) -> tuple[
    list[AnalyzedProduct],
    dict[str, MatchedSupplier],
    dict[str, CopyDraft],
    dict[str, AIRecommendation],
    dict[str, ListingCopyAsset],
    dict[str, ImageAsset],
]:
    raw_products = _load_raw_products(use_sample_fallback=use_sample_fallback)
    analyzed_products = _load_or_build_analyzed_products(raw_products)
    candidate_products = [product for product in analyzed_products if not product.skip_reason]
    suppliers = _load_or_build_suppliers(candidate_products)
    copies = _load_or_build_copies(candidate_products, suppliers)
    ai_recommendations, listing_copy_assets, image_assets = _build_ai_assets(candidate_products, suppliers)
    return analyzed_products, suppliers, copies, ai_recommendations, listing_copy_assets, image_assets


def build_candidate_bundles() -> list[CandidateBundle]:
    analyzed_products, suppliers, copies, ai_recommendations, listing_copy_assets, image_assets = build_pipeline_outputs(
        use_sample_fallback=False
    )
    return build_candidate_bundles_from_parts(
        analyzed_products=analyzed_products,
        suppliers=suppliers,
        copies=copies,
        decisions=load_decisions(),
        ai_recommendations=ai_recommendations,
        listing_copy_assets=listing_copy_assets,
        image_assets=image_assets,
    )



def build_candidate_bundles_from_parts(
    analyzed_products: list[AnalyzedProduct],
    suppliers: dict[str, MatchedSupplier],
    copies: dict[str, CopyDraft],
    decisions: dict[str, DecisionRecord] | None = None,
    ai_recommendations: dict[str, AIRecommendation] | None = None,
    listing_copy_assets: dict[str, ListingCopyAsset] | None = None,
    image_assets: dict[str, ImageAsset] | None = None,
) -> list[CandidateBundle]:
    candidate_products = [product for product in analyzed_products if not product.skip_reason]
    resolved_decisions = decisions or {}
    resolved_ai_recommendations = ai_recommendations or {}
    resolved_listing_copy_assets = listing_copy_assets or {}
    resolved_image_assets = image_assets or {}

    if not resolved_ai_recommendations or not resolved_listing_copy_assets or not resolved_image_assets:
        built_ai_recommendations, built_listing_copy_assets, built_image_assets = _build_ai_assets(candidate_products, suppliers)
        resolved_ai_recommendations = resolved_ai_recommendations or built_ai_recommendations
        resolved_listing_copy_assets = resolved_listing_copy_assets or built_listing_copy_assets
        resolved_image_assets = resolved_image_assets or built_image_assets

    return [
        CandidateBundle(
            product=product,
            supplier=suppliers.get(product.id),
            copy_draft=copies.get(product.id),
            decision=resolved_decisions.get(product.id),
            ai_recommendation=resolved_ai_recommendations.get(product.id),
            listing_copy_asset=resolved_listing_copy_assets.get(product.id),
            image_asset=resolved_image_assets.get(product.id),
        )
        for product in candidate_products
    ]


def _load_raw_products(use_sample_fallback: bool) -> list[RawProduct]:
    if RAW_PATH.exists():
        return [RawProduct.model_validate(item) for item in _read_json(RAW_PATH)]

    scraper = ProductScraper(use_real_source=True, use_sample_fallback=use_sample_fallback)
    products = scraper.scrape(platform="all", count=20)
    return [RawProduct.model_validate(item) for item in products]


def _load_or_build_analyzed_products(raw_products: list[RawProduct]) -> list[AnalyzedProduct]:
    if ANALYZED_PATH.exists():
        return [AnalyzedProduct.model_validate(item) for item in _read_json(ANALYZED_PATH)]
    return analyze_products(raw_products)


def _load_or_build_suppliers(products: list[AnalyzedProduct]) -> dict[str, MatchedSupplier]:
    if MATCHED_PATH.exists():
        return {
            supplier.product_id: supplier
            for supplier in (MatchedSupplier.model_validate(item) for item in _read_json(MATCHED_PATH))
        }
    return {supplier.product_id: supplier for supplier in match_suppliers(products)}


def _load_or_build_copies(products: list[AnalyzedProduct], suppliers: dict[str, MatchedSupplier]) -> dict[str, CopyDraft]:
    if COPY_PATH.exists():
        return {
            draft.product_id: draft
            for draft in (CopyDraft.model_validate(item) for item in _read_json(COPY_PATH))
        }
    return {draft.product_id: draft for draft in build_copy_drafts(products, suppliers)}


def _build_ai_assets(
    products: list[AnalyzedProduct],
    suppliers: dict[str, MatchedSupplier],
) -> tuple[dict[str, AIRecommendation], dict[str, ListingCopyAsset], dict[str, ImageAsset]]:
    builder = AIAssetBuilder()
    recommendations: dict[str, AIRecommendation] = {}
    listing_assets: dict[str, ListingCopyAsset] = {}
    image_assets: dict[str, ImageAsset] = {}

    for product in products:
        recommendation = builder.build_recommendation(product, suppliers.get(product.id))
        recommendations[product.id] = recommendation
        listing_assets[product.id] = builder.build_listing_copy_asset(product, recommendation)
        image_assets[product.id] = builder.build_image_asset(product, recommendation)

    return recommendations, listing_assets, image_assets



def _read_json(path: Path) -> list[dict]:
    return json.loads(path.read_text(encoding="utf-8"))
