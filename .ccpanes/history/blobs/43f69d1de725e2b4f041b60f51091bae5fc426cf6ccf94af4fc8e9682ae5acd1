from __future__ import annotations

from collections import Counter
from datetime import datetime, timezone

import requests
import streamlit as st

from app.main import summarize_platform_opportunities
from app.pipeline import build_candidate_bundles
from app.schemas import CandidateBundle, Decision, DecisionRecord, Platform, SearchHit, SearchRequest, SearchSession
from app.storage import load_blacklist_summary, load_decisions, load_profit_summary, save_decision
from platforms.defaults import register_default_platforms
from platforms.registry import registry

DECISION_LABELS = {
    Decision.APPROVED: "通过",
    Decision.SKIPPED: "跳过",
    Decision.BLACKLISTED: "拉黑",
}

LABEL_TO_DECISION = {label: decision for decision, label in DECISION_LABELS.items()}

register_default_platforms()

API_BASE_URL = "http://127.0.0.1:8000"
SEARCH_MODE_LABEL = "实时搜索工作台"


def _get_candidates() -> list[CandidateBundle]:
    return build_candidate_bundles()


def _search_session_key() -> str:
    return "search-session"


def _search_hits_key() -> str:
    return "search-hits"


def _api_error_key() -> str:
    return "search-api-error"


def _selected_hit_key() -> str:
    return "search-selected-hit"


def _fetch_search_session() -> SearchSession | None:
    return st.session_state.get(_search_session_key())


def _fetch_search_hits() -> list[SearchHit]:
    return st.session_state.get(_search_hits_key(), [])


def _store_search_state(session: SearchSession, hits: list[SearchHit]) -> None:
    st.session_state[_search_session_key()] = session
    st.session_state[_search_hits_key()] = hits
    st.session_state[_api_error_key()] = None


def _platform_label(platform: Platform) -> str:
    return platform.value


def _call_search_api(keyword: str, platforms: list[Platform], limit_per_platform: int, backend: str) -> None:
    payload = SearchRequest(
        keyword=keyword,
        platforms=platforms,
        limit_per_platform=limit_per_platform,
        backend=backend,
    )
    response = requests.post(
        f"{API_BASE_URL}/api/search",
        json=payload.model_dump(mode="json"),
        timeout=60,
    )
    response.raise_for_status()
    session_payload = response.json()["session"]
    session = SearchSession.model_validate(session_payload)

    hits_response = requests.get(f"{API_BASE_URL}/api/search/{session.id}/hits", timeout=30)
    hits_response.raise_for_status()
    hits_payload = hits_response.json()
    hits = [SearchHit.model_validate(item) for item in hits_payload["hits"]]
    session = SearchSession.model_validate(hits_payload["session"])
    _store_search_state(session, hits)


def _render_search_workspace() -> None:
    st.subheader(SEARCH_MODE_LABEL)
    current_session = _fetch_search_session()
    current_hits = _fetch_search_hits()

    with st.form("search-form"):
        keyword = st.text_input("平台搜索关键词", value="收纳", placeholder="例如：收纳 / 宿舍灯 / 蓝牙耳机")
        selected_platform_values = st.multiselect(
            "平台",
            options=[platform.value for platform in Platform],
            default=[platform.value for platform in Platform],
        )
        limit_per_platform = st.slider("每个平台抓取数量", min_value=1, max_value=10, value=5)
        backend = st.selectbox("抓取后端", options=["auto", "browser", "proxy", "text"], index=0)
        submitted = st.form_submit_button("开始抓取")

    if submitted:
        normalized_keyword = keyword.strip()
        selected_platforms = [Platform(value) for value in selected_platform_values]
        if not normalized_keyword:
            st.session_state[_api_error_key()] = "关键词不能为空"
        elif not selected_platforms:
            st.session_state[_api_error_key()] = "至少选择一个平台"
        else:
            try:
                _call_search_api(normalized_keyword, selected_platforms, limit_per_platform, backend)
                current_session = _fetch_search_session()
                current_hits = _fetch_search_hits()
            except requests.RequestException as exc:
                st.session_state[_api_error_key()] = f"搜索接口调用失败：{exc}"

    api_error = st.session_state.get(_api_error_key())
    if api_error:
        st.error(api_error)

    if current_session is None:
        st.info("请输入关键词并发起抓取，结果会显示在下方。")
        return

    summary = current_session.summary
    top_left, top_mid, top_right = st.columns(3)
    top_left.metric("任务状态", current_session.status.value)
    top_mid.metric("命中数", current_session.hit_count)
    top_right.metric("关键词", current_session.keyword)

    st.caption(
        f"平台：{', '.join(_platform_label(platform) for platform in current_session.platforms)}"
        f" / backend={current_session.backend}"
        f" / 创建时间：{current_session.created_at.isoformat()}"
    )
    if current_session.error_message:
        st.warning(current_session.error_message)

    if summary.platform_counts:
        st.write({"platform_counts": summary.platform_counts, "data_source_counts": summary.data_source_counts})

    if not current_hits:
        st.info("本次搜索暂无命中结果。")
        return

    rows = [
        {
            "rank": hit.rank,
            "platform": hit.platform.value,
            "title": hit.product.title,
            "price": hit.product.price,
            "want_count": hit.product.want_count,
            "sales_count": hit.product.sales_count,
            "category": hit.product.category,
            "data_source": hit.product.data_source,
            "product_id": hit.product.id,
        }
        for hit in current_hits
    ]
    st.dataframe(rows, use_container_width=True, hide_index=True)

    hit_options = {
        f"{hit.platform.value}#{hit.rank} | {hit.product.title}": hit.product.id
        for hit in current_hits
    }
    selected_label = st.selectbox("查看命中详情", options=list(hit_options.keys()))
    st.session_state[_selected_hit_key()] = hit_options[selected_label]
    selected_id = st.session_state[_selected_hit_key()]
    selected_hit = next((hit for hit in current_hits if hit.product.id == selected_id), None)
    if selected_hit is None:
        return

    left, right = st.columns(2)
    with left:
        st.write(f"平台：{selected_hit.platform.value}")
        st.write(f"标题：{selected_hit.product.title}")
        st.write(f"价格：¥{selected_hit.product.price:.2f}")
        st.write(f"类目：{selected_hit.product.category or '-'}")
    with right:
        st.write(f"想要人数：{selected_hit.product.want_count or 0}")
        st.write(f"销量：{selected_hit.product.sales_count or 0}")
        st.write(f"来源：{selected_hit.product.data_source}")
        st.write(f"source_detail：{selected_hit.product.source_detail or '-'}")


def _decision_state_key(product_id: str) -> str:
    return f"decision-state-{product_id}"


def _decision_note_key(product_id: str) -> str:
    return f"decision-note-{product_id}"


def _load_decision(product_id: str) -> DecisionRecord | None:
    if _decision_state_key(product_id) not in st.session_state:
        st.session_state[_decision_state_key(product_id)] = load_decisions().get(product_id)
    return st.session_state.get(_decision_state_key(product_id))


def _save_decision(candidate: CandidateBundle, decision: Decision, reason: str | None) -> None:
    record = DecisionRecord(
        product_id=candidate.product.id,
        decision=decision,
        reason=reason,
        decided_by="dashboard-user",
        decided_at=datetime.now(timezone.utc),
    )
    st.session_state[_decision_state_key(candidate.product.id)] = record
    save_decision(
        record,
        supplier_name=candidate.supplier.supplier_name if candidate.supplier else None,
        category_label=candidate.product.category_label,
        profit_est=candidate.supplier.profit_est if candidate.supplier else None,
        supplier_id=candidate.supplier.supplier_id if candidate.supplier else None,
    )


def _decision_summary(candidates: list[CandidateBundle]) -> dict[Decision, int]:
    counter: Counter[Decision] = Counter()
    for candidate in candidates:
        record = _load_decision(candidate.product.id)
        if record is not None:
            counter[record.decision] += 1
    return {decision: counter.get(decision, 0) for decision in Decision}


def _filter_candidates(
    candidates: list[CandidateBundle],
    min_score: float,
    selected_platforms: list[str],
    decision_filter: str,
    keyword_query: str,
) -> list[CandidateBundle]:
    normalized_query = keyword_query.strip().lower()
    filtered: list[CandidateBundle] = []
    for candidate in candidates:
        if candidate.product.product_score < min_score:
            continue
        platform_code = candidate.product.platform_code or candidate.product.platform.value
        if platform_code not in selected_platforms:
            continue

        record = _load_decision(candidate.product.id)
        if decision_filter == "未处理" and record is not None:
            continue
        if decision_filter != "全部":
            expected = LABEL_TO_DECISION.get(decision_filter)
            if expected is not None and (record is None or record.decision != expected):
                continue

        if normalized_query:
            haystacks = [candidate.product.title, *candidate.product.keywords]
            if candidate.supplier:
                haystacks.append(candidate.supplier.supplier_name)
            if not any(normalized_query in text.lower() for text in haystacks):
                continue

        filtered.append(candidate)
    return filtered


def render_candidate_card(index: int, candidate: CandidateBundle) -> None:
    st.subheader(f"候选商品 {index}: {candidate.product.title}")
    left, right = st.columns(2)

    with left:
        st.metric("潜力评分", f"{candidate.product.product_score:.0f}")
        st.write(f"趋势：{candidate.product.trend.value}")
        st.write(f"平台：{candidate.product.platform_code or candidate.product.platform.value}")
        st.write(f"售价：¥{candidate.product.price:.2f}")
        st.write(f"关键词：{' / '.join(candidate.product.keywords)}")

    with right:
        if candidate.supplier:
            st.metric("预估利润", f"¥{candidate.supplier.profit_est:.2f}")
            st.write(f"货源商家：{candidate.supplier.supplier_name}")
            st.write(f"货源价：¥{candidate.supplier.source_price:.2f}")
            st.write(f"无痕发货：{'是' if candidate.supplier.plain_package else '否'}")

    if candidate.copy_draft:
        st.caption(f"模板：{candidate.copy_draft.template_id}")
        st.write(candidate.copy_draft.title)
        st.write(candidate.copy_draft.body)
        st.write(f"标签：{'、'.join(candidate.copy_draft.tags)}")

    if candidate.ai_recommendation:
        st.caption(f"AI 推荐：卖到 {candidate.ai_recommendation.recommended_sell_platform} / 进货自 {candidate.ai_recommendation.recommended_source_platform}")
        st.write(
            f"AI 机会分：{candidate.ai_recommendation.opportunity_score:.1f}"
            f" / 置信度：{candidate.ai_recommendation.confidence_score:.2f}"
        )
        for reason in candidate.ai_recommendation.reasoning:
            st.write(f"- {reason}")
        if candidate.ai_recommendation.risk_flags:
            st.warning(f"风险提示：{'、'.join(candidate.ai_recommendation.risk_flags)}")

    if candidate.listing_copy_asset and candidate.listing_copy_asset.variants:
        st.caption("AI 销售文案")
        for variant in candidate.listing_copy_asset.variants[:2]:
            st.write(f"[{variant.channel}] {variant.title}")
            st.write(variant.body)

    if candidate.image_asset:
        st.caption("AI 配图方案")
        st.write(candidate.image_asset.prompt_spec.prompt)

    decision_label = st.radio(
        "人工决策",
        options=list(LABEL_TO_DECISION.keys()),
        horizontal=True,
        key=f"decision-{candidate.product.id}",
    )
    reason = st.text_input(
        "决策备注",
        value=st.session_state.get(_decision_note_key(candidate.product.id), ""),
        key=_decision_note_key(candidate.product.id),
        placeholder="记录跳过原因、拉黑原因或通过备注",
    )

    if st.button("保存决策", key=f"save-{candidate.product.id}"):
        decision = LABEL_TO_DECISION[decision_label]
        _save_decision(candidate, decision, reason.strip() or None)
        st.success("决策已记录")

    record = _load_decision(candidate.product.id)
    if record is not None:
        st.info(
            f"已记录：{DECISION_LABELS[record.decision]} / 操作人：{record.decided_by}"
            f" / 时间：{record.decided_at.isoformat()}"
            f"{f' / 备注：{record.reason}' if record.reason else ''}"
        )

    st.divider()


def main() -> None:
    st.set_page_config(page_title="AI 选品助手", layout="wide")
    st.title("AI 选品助手 Dashboard")
    st.write("当前页面默认进入实时搜索工作台，不再展示内置样本或假数据候选页。")
    _render_search_workspace()


if __name__ == "__main__":
    main()
