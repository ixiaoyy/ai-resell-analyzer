from __future__ import annotations

import argparse
import json
from collections import Counter
from pathlib import Path

from platforms.defaults import register_default_platforms
from platforms.registry import registry
from scraper.fetchers import FetchBackend, FetchError, _classify_fetch_error, fetch_real_products
from scraper.mock_data import build_sample_raw_products


register_default_platforms()

DEFAULT_OUTPUT_DIR = Path("data/raw")


class ScraperError(Exception):
    """Raised when scraper input or output is invalid."""


class ProductScraper:
    def __init__(
        self,
        use_real_source: bool = True,
        use_sample_fallback: bool = False,
        backend: FetchBackend = "auto",
    ) -> None:
        self.use_real_source = use_real_source
        self.use_sample_fallback = use_sample_fallback
        self.backend = backend

    def scrape(self, platform: str = "all", count: int = 5) -> list[dict]:
        if platform not in supported_platform_codes():
            raise ScraperError("Invalid platform")
        if count < 1:
            raise ScraperError("count must be greater than 0")

        fetch_error_category: str | None = None

        if self.use_real_source:
            try:
                products = fetch_real_products(platform=platform, limit=count, backend=self.backend)
                if products:
                    return [
                        {
                            **item,
                            "data_source": item.get("data_source") or "real",
                            "backend_used": item.get("backend_used") or self.backend,
                            "source_detail": item.get("source_detail") or f"real:{platform}",
                            "fetch_error_category": None,
                        }
                        for item in products[:count]
                    ]
            except FetchError as exc:
                fetch_error_category = _classify_fetch_error(str(exc))
                if not self.use_sample_fallback:
                    raise ScraperError("Real fetch failed and sample fallback is disabled") from None

        if self.use_sample_fallback:
            return self._sample_products(platform=platform, count=count, fetch_error_category=fetch_error_category)

        return []

    def _sample_products(self, platform: str, count: int, fetch_error_category: str | None = None) -> list[dict]:
        products = [product.model_dump(mode="json") for product in build_sample_raw_products()]
        if platform != "all":
            products = [item for item in products if item["platform"] == platform]
        return [
            {
                **item,
                "data_source": "sample",
                "backend_used": "sample",
                "source_detail": f"sample:{platform}",
                "fetch_error_category": fetch_error_category,
            }
            for item in products[:count]
        ]


def summarize_products(products: list[dict]) -> dict[str, object]:
    data_source_counts = Counter(str(item.get("data_source") or "unknown") for item in products)
    backend_counts = Counter(str(item.get("backend_used") or "unknown") for item in products)
    error_counts = Counter(str(item.get("fetch_error_category") or "none") for item in products)
    platform_counts = Counter(str(item.get("platform") or "unknown") for item in products)

    return {
        "total": len(products),
        "data_sources": dict(sorted(data_source_counts.items())),
        "backends": dict(sorted(backend_counts.items())),
        "error_categories": dict(sorted(error_counts.items())),
        "platforms": dict(sorted(platform_counts.items())),
    }



def print_scrape_summary(summary: dict[str, object]) -> None:
    def _format_mapping(value: object) -> str:
        if not isinstance(value, dict) or not value:
            return "none"
        return ", ".join(f"{key}={count}" for key, count in value.items())

    print(f"scrape summary: total={summary['total']}")
    print(f"  platforms: {_format_mapping(summary.get('platforms'))}")
    print(f"  data_sources: {_format_mapping(summary.get('data_sources'))}")
    print(f"  backends: {_format_mapping(summary.get('backends'))}")
    print(f"  error_categories: {_format_mapping(summary.get('error_categories'))}")



def build_output_path(platform: str, output: Path | None) -> Path:
    if output is not None:
        return output
    DEFAULT_OUTPUT_DIR.mkdir(parents=True, exist_ok=True)
    return DEFAULT_OUTPUT_DIR / f"{platform}_latest.json"


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="导出抓取数据，支持浏览器级、专用代理和文本代理多级抓取")
    parser.add_argument("--platform", default="all", help="按平台过滤输出结果")
    parser.add_argument("--limit", type=int, default=100, help="限制输出条数")
    parser.add_argument("--output", type=Path, default=None, help="输出 JSON 文件路径")
    parser.add_argument("--sample-only", action="store_true", help="仅使用本地样本，不发起真实抓取")
    parser.add_argument("--no-fallback", action="store_true", help="真实抓取失败时不回退样本")
    parser.add_argument(
        "--backend",
        choices=["auto", "browser", "proxy", "text"],
        default="auto",
        help="抓取后端：auto=浏览器→专用代理→文本代理，browser=仅 Playwright，proxy=仅 Firecrawl，text=仅 Jina",
    )
    args = parser.parse_args()
    if args.platform not in supported_platform_codes():
        parser.error(f"--platform must be one of: {', '.join(supported_platform_codes())}")
    return args


def main() -> int:
    args = parse_args()
    scraper = ProductScraper(
        use_real_source=not args.sample_only,
        use_sample_fallback=not args.no_fallback,
        backend=args.backend,
    )
    products = scraper.scrape(platform=args.platform, count=args.limit)
    summary = summarize_products(products)
    output_path = build_output_path(args.platform, args.output)
    output_path.parent.mkdir(parents=True, exist_ok=True)
    output_path.write_text(json.dumps(products, ensure_ascii=False, indent=2), encoding="utf-8")
    print(f"exported {len(products)} products to {output_path}")
    print_scrape_summary(summary)
    return 0


def supported_platform_codes() -> tuple[str, ...]:
    demand_codes = registry.codes(role="demand")
    return ("all", *demand_codes)


if __name__ == "__main__":
    raise SystemExit(main())
